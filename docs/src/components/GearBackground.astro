---
import { buildDebugOverlay, buildGearPath, createMeshedPairScene, solveGearScene } from "../lib/gears";

const debugMeshes = false;

const scene = createMeshedPairScene({
  circularPitch: 34,
  minTeeth: 12,
  driverId: "gear-large",
  driverPeriodSec: 120,
  driverDirection: "cw",
  first: {
    id: "gear-large",
    center: { x: 280, y: 252 },
    targetPitchRadius: 130,
  },
  second: {
    id: "gear-small",
    idealCenter: { x: 136, y: 116 },
    targetPitchRadius: 65,
  },
});

const solvedScene = solveGearScene(scene);
const debugOverlay = buildDebugOverlay(solvedScene);
const sceneWidth = 430;
const sceneHeight = 370;
---
<div class="gear-background" aria-hidden="true">
  <svg
    class="gear-scene"
    viewBox={`0 0 ${sceneWidth} ${sceneHeight}`}
    xmlns="http://www.w3.org/2000/svg"
    role="presentation"
  >
    {solvedScene.gears.map((gear) => (
      <g transform={`translate(${gear.center.x} ${gear.center.y})`}>
        <g
          class:list={[
            "gear-rotor",
            { "gear-rotor-cw": gear.rotationDirection === "cw", "gear-rotor-ccw": gear.rotationDirection === "ccw" },
          ]}
          style={`--gear-phase:${gear.phaseDeg}deg; --gear-period:${gear.periodSec}s;`}
        >
          <path class="gear-outline" d={buildGearPath(gear)} />
          <circle class="gear-inner-ring" r={gear.innerRingRadius} />
          <circle class="gear-hub" r={gear.holeRadius} />
        </g>
      </g>
    ))}

    {debugMeshes &&
      debugOverlay.circles.map((circle) => (
        <circle
          class:list={[
            "gear-debug-circle",
            `gear-debug-${circle.kind}`,
          ]}
          cx={circle.center.x}
          cy={circle.center.y}
          r={circle.radius}
        />
      ))}

    {debugMeshes &&
      debugOverlay.lines.map((line) => (
        <line
          class="gear-debug-line"
          x1={line.from.x}
          y1={line.from.y}
          x2={line.to.x}
          y2={line.to.y}
        />
      ))}
  </svg>
</div>

<style>
  .gear-background {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .gear-scene {
    position: absolute;
    right: -46px;
    bottom: -46px;
    width: 430px;
    height: 370px;
    color: var(--brass-primary);
    opacity: var(--gear-opacity, 0.03);
    overflow: visible;
  }

  .gear-outline,
  .gear-inner-ring,
  .gear-hub {
    fill: none;
    stroke: currentColor;
    vector-effect: non-scaling-stroke;
  }

  .gear-outline {
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .gear-inner-ring,
  .gear-hub {
    stroke-width: 1;
  }

  .gear-rotor {
    transform-box: fill-box;
    transform-origin: center;
  }

  .gear-rotor-cw {
    animation: gear-spin-cw var(--gear-period) linear infinite;
  }

  .gear-rotor-ccw {
    animation: gear-spin-ccw var(--gear-period) linear infinite;
  }

  @keyframes gear-spin-cw {
    from {
      transform: rotate(var(--gear-phase));
    }
    to {
      transform: rotate(calc(var(--gear-phase) + 360deg));
    }
  }

  @keyframes gear-spin-ccw {
    from {
      transform: rotate(var(--gear-phase));
    }
    to {
      transform: rotate(calc(var(--gear-phase) - 360deg));
    }
  }

  .gear-debug-circle,
  .gear-debug-line {
    fill: none;
    stroke-width: 0.75;
    vector-effect: non-scaling-stroke;
  }

  .gear-debug-pitch {
    stroke: rgba(91, 191, 173, 0.55);
  }

  .gear-debug-root {
    stroke: rgba(196, 75, 63, 0.45);
  }

  .gear-debug-outer,
  .gear-debug-line {
    stroke: rgba(240, 216, 120, 0.45);
  }

  @media (prefers-reduced-motion: reduce) {
    .gear-rotor-cw,
    .gear-rotor-ccw {
      animation: none;
      transform: rotate(var(--gear-phase));
    }
  }

  @media (max-width: 767px) {
    .gear-background {
      display: none;
    }
  }
</style>
